{
  "version": 2,
  "framework": "vite",
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/_sam/(.*)",
      "dest": "/_sam/$1",
      "check": true
    },
    {
      "src": "/(.*)",
      "dest": "/",
      "check": true
    }
  ]
}
